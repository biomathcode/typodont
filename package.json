{
  "name": "typodont",
  "version": "0.0.1",
  "description": "",
  "scripts": {
    "install:all": "pnpm -r install",
    "watch": "pnpm --filter=typodont dev",
    "dev": "pnpm run watch --onSuccess \"pnpm -w run site:dev\"",
    "build": "pnpm --filter=typodont build",
    "test": "pnpm --filter=typodont test",
    "site:dev": "pnpm --filter=site dev",
    "site:build": "pnpm run build && pnpm --filter=site build",
    "lint": "pnpm --filter=typodont lint",
    "lint:fix": "pnpm --filter=typodont lint:fix",
    "pre-commit": "pnpm run --filter=typodont pre-commit",
    "version": "changeset version && git add --all",
    "release": "pnpm build && changeset publish && git push --follow-tags"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "@commitlint/cli": "^17.8.0",
    "@commitlint/config-conventional": "^17.8.0",
    "lint-staged": "^15.0.2"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.1"
}
